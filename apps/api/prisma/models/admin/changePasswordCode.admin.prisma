model ChangePasswordCodeAdmin {
  adminId          String   @id  // @id вместо @unique — одна запись, она и есть ключ
  codeHash        String
  newPasswordHash String
  expiresAt       DateTime
  attempts        Int      @default(0)
  resendCount     Int      @default(0)
  lastResendAt    DateTime?
  blockedAt       DateTime?
  status          ChangePasswordCodeStatus @default(PENDING)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("changePasswordCodeAdmin")
}

