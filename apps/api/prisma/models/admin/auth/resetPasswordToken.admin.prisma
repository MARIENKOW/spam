model ResetPasswordTokenAdmin {
  id         String   @id @default(cuid())
  adminId     String   @unique
  admin       Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  tokenHash  String   

  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@map("resetPasswordTokenAdmin")
  @@index(adminId)
  @@index(expiresAt)
}