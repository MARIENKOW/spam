// Добавить в schema.prisma
model Image {
    id         String          @id @default(uuid())
    entityType FileEntityType // определяет папку и уровень доступа
    filename   String          // UUID.webp / UUID.jpg
    mimeType   String          // image/webp / image/jpeg
    path       String?
    width      Int
    user User? // обратная связь — без неё Prisma не скомпилирует
    admin Admin? // обратная связь — без неё Prisma не скомпилирует
    blog     Blog?   @relation("BlogMainImage")
    blogBody Blog[]  @relation("BlogBodyImages")
    video      Video?     // обратная связь — без неё Prisma не скомпилирует
    tgAccount  TgAccount? // обратная связь
    height     Int
    size       Int             // байты
    createdAt  DateTime        @default(now())
    

    @@index([entityType])
}
